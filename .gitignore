# .gitignore для репозитория Companion
# Unity-проект лежит в подпапке Companion/. Шаблоны не привязаны к корню (без
# ведущего /), поэтому корректно срабатывают и для вложенной папки проекта.
# База: https://github.com/github/gitignore/blob/main/Unity.gitignore

# === Генерируемые Unity папки ===
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset Bundles / Addressables (большие бинарники)
**/[Aa]ssets/[Aa]sset[Bb]undles/
**/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# .meta игнорируем только вместе с самим ассетом — здесь возвращаем обратно
!**/[Aa]ssets/**/*.meta

# === Файлы IDE и сборки проектов (генерируются Unity) ===
.vs/
.vscode/
.idea/
.consulo/
*.csproj
*.sln
*.slnx
*.unityproj
*.user
*.suo
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# === Артефакты сборки / билды ===
*.apk
*.aab
*.app
*.unitypackage
*.unitypackage.meta
ExportedObj/
[Ee]xport-[Aa]ndroid/
.gradle/
crashlytics-build.properties
sysinfo.txt

# === Прочее ===
*.tmp
*.stackdump
.DS_Store
Thumbs.db

# === Временные/одноразовые скрипты Claude (см. CLAUDE.md) ===
tmp_*.py
**/__pycache__/
